# Copie para .env e ajuste. Prefixo RAG_ em todas as variáveis.
# Defaults apontam para o docker-compose do monorepo (portas com offset +10).

# Vector store (serviço qdrant do compose)
RAG_QDRANT_URL=http://localhost:6343
RAG_QDRANT_COLLECTION=documents

# Fila (serviço rabbitmq do compose)
RAG_RABBITMQ_URL=amqp://guest:guest@localhost:5682/

# Object storage (serviço minio do compose) — de onde o worker lê os arquivos.
RAG_MINIO_ENDPOINT=localhost:9010
RAG_MINIO_ACCESS_KEY=mlp
RAG_MINIO_SECRET_KEY=mlpsecret123
# Deve ser IGUAL ao MINIO_SOURCE_FILE_BUCKET do Nest (bucket dos arquivos).
RAG_MINIO_BUCKET=source-files
RAG_MINIO_SECURE=false

# Integração com o Nest (apps/api em :3333) — OBRIGATÓRIOS (boot falha se faltar)
RAG_NEST_BASE_URL=http://localhost:3333
# Deve ser IGUAL ao INTERNAL_API_TOKEN do Nest.
RAG_NEST_SERVICE_TOKEN=troque-por-um-token-de-servico

# Token exigido no /search (defesa em profundidade) — OBRIGATÓRIO.
# O Nest envia este mesmo valor (SEARCH_SERVICE_TOKEN) ao fazer proxy.
RAG_SERVICE_API_TOKEN=troque-por-um-token-de-busca

# Confiabilidade do worker
RAG_RABBITMQ_HEARTBEAT=600
RAG_MAX_RETRIES=3
RAG_RETRY_TTL_MS=10000

# Modelos: GPU (RTX 4060 Ti via WSL2). Use "cpu" só se não houver GPU.
RAG_DEVICE=cuda

# RAG generativo (/answer): LLM local via Ollama (serviço ollama do compose).
RAG_OLLAMA_URL=http://localhost:11434/api/chat
RAG_LLM_MODEL=qwen2.5:7b-instruct
RAG_OLLAMA_TIMEOUT=300
# Só entram no contexto trechos com score de rerank >= limiar (anti-alucinação).
RAG_ANSWER_MIN_SCORE=0.05
RAG_ANSWER_TOP_K=5
RAG_ANSWER_MAX_CONTEXT_CHARS=8000
