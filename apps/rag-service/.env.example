# Copie para .env e ajuste. Prefixo RAG_ em todas as variáveis.

# Infra (default de dev já aponta para o docker-compose local)
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=documents
RAG_RABBITMQ_URL=amqp://rag:rag@localhost:5673/

# Integração com o Nest — OBRIGATÓRIOS (sem default; boot falha se faltar)
RAG_NEST_BASE_URL=http://localhost:3000
RAG_NEST_SERVICE_TOKEN=troque-por-um-token-de-servico

# Token exigido no /search (defesa em profundidade) — OBRIGATÓRIO
RAG_SERVICE_API_TOKEN=troque-por-um-token-de-busca

# Confiabilidade do worker
RAG_RABBITMQ_HEARTBEAT=600
RAG_MAX_RETRIES=3
RAG_RETRY_TTL_MS=10000

# Modelos ("cuda" no container WSL com GPU; "cpu" no dev Windows)
RAG_DEVICE=cpu
