{
  "name": "@my-little-pony/web",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.23.0",
    "next": "~16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "nx": {
    "targets": {
      "typecheck": {
        "command": "tsc --noEmit -p apps/web/tsconfig.json",
        "cache": true,
        "inputs": [
          "default",
          "^default"
        ]
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "apps/web"
        },
        "cache": true,
        "inputs": [
          "default",
          "^default"
        ]
      }
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  }
}
