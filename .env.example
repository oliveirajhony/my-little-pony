# App
PORT=3333

# Postgres (host port 5442 to coexist with other local stacks)
DATABASE_URL=postgres://mlp:mlp@localhost:5442/mlp

# Redis (host port 6389)
REDIS_URL=redis://localhost:6389

# RabbitMQ (host port 5682; management UI at localhost:15682)
RABBITMQ_URL=amqp://guest:guest@localhost:5682

# Secrets (NO DEFAULTS — the boot fails if any of these is missing).
# Generate locally with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_API_TOKEN=

# Token TTLs
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS: origem do app web permitida (default http://localhost:3000)
WEB_ORIGIN=http://localhost:3000

# URL pública da API (usada para montar os links de avatar)
API_PUBLIC_URL=http://localhost:3334

# MinIO (armazenamento de objetos — credenciais de dev local, não são segredos)
MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_ACCESS_KEY=mlp
MINIO_SECRET_KEY=mlpsecret123
MINIO_BUCKET=avatars
# Bucket dos documentos-fonte importados (deve casar com RAG_MINIO_BUCKET).
MINIO_SOURCE_FILE_BUCKET=source-files

# Serviço Python de busca + RAG (apps/rag-service). Vazio => busca/Explorar
# degradam graciosamente (sem resultados / "indisponível"). Para ligar:
SEARCH_SERVICE_URL=http://localhost:8000
# Deve ser IGUAL ao RAG_SERVICE_API_TOKEN do rag-service.
SEARCH_SERVICE_TOKEN=

# SMTP para envio de e-mail.
# DEV (padrão): Mailpit captura tudo em http://localhost:8025 e NÃO envia nada
# para caixas reais — é só para inspecionar os e-mails localmente.
# PROD: aponte para um provedor real (Resend, SendGrid, SES, Gmail SMTP…):
#   SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_SECURE=true
#   SMTP_USER=resend  SMTP_PASS=<api-key>  MAIL_FROM="Meu App <no-reply@seu-dominio.com>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=my-little-pony <no-reply@mlp.local>
